# Copy this file to .env and fill in local/private values.
# .env is gitignored and should not be committed.
# Tool-specific overrides may live in tools/<name>/.env and take precedence.

# === ICS / SSO ===
ICS_BASE_URL=https://ics.example.com:48011
# User filter for sprint/ticket queries (also used as fallback for SSO ID).
ICS_ID=your-sso-id
# Login ID for SSO automation. Falls back to ICS_ID if unset.
# ICS_SSO_ID=your-sso-id
# Prefer keyring for passwords. Use ICS_SSO_PW only for local testing.
# ICS_SSO_PW=
ICS_KEYRING_SERVICE=ICS_SSO
# Browser for ICS automation: edge | chrome | ...
# ICS_BROWSER=edge
# ICS_BROWSER_BINARY=
# Optional shell command to run after a successful ICS login.
# ICS_POST_SCRIPT=

# === Teams ===
TEAMS_SELF_UPN=your.name@example.com
TEAMS_TENANT_ID=your-tenant-id
TEAMS_CHAT_URL=https://teams.microsoft.com/l/chat/<chat-thread-id>/conversations?context=...
TEAMS_CHAT_DEEP_LINK_BASE=https://teams.microsoft.com/l/chat/0/0?
TEAMS_AUTHOR_ALIASES=your.name@example.com=Display Name|Korean Name
# Browser / profile for Teams web automation
# TEAMS_BROWSER=auto
# TEAMS_BROWSER_BINARY=
# TEAMS_PROFILE_DIR=
# TEAMS_DOWNLOAD_DIR=
# Send behavior
# TEAMS_INPUT_METHOD=
# TEAMS_SEND_KEY=
# TEAMS_SEND_METHOD=
# TEAMS_MESSAGE_PREFIX=
# Webhook posting (tools/teams/post_ics_to_teams.py)
# TEAMS_PAYLOAD_MODE=workflow
# TEAMS_WEBHOOK_URL=

# === SharePoint / M365 ===
SP_USER=your.name@example.com
SP_SITE=https://example.sharepoint.com/sites/YourSite
SP_FOLDER_REL=/sites/YourSite/Shared Documents/Folder
SP_FOLDER_PAGE=https://example.sharepoint.com/sites/YourSite/Shared%20Documents/Forms/AllItems.aspx
SP_KEYRING_SERVICE=M365_SP
# Prefer keyring for passwords. Use SP_PASSWORD only for local testing.
# SP_PASSWORD=
